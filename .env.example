# 本番管理画面のログイン情報（このファイルはテンプレートです）
# 使い方:
#   cp .env.example .env.local
#   .env.local の値を編集（.env.local は Git に含めません）
#
# ADMIN_SESSION_TOKEN は推測されにくいランダム文字列にしてください。
# 例: openssl rand -hex 32

ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password
ADMIN_SESSION_TOKEN=your-random-session-token
